# ============================================================
# WhatsApp (Meta Cloud API)
# ============================================================
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_VERIFY_TOKEN=
META_WA_APP_SECRET=
USER_WHATSAPP_NUMBER=                  # Yash's WhatsApp in international format, e.g. 91XXXXXXXXXX
APPROVED_TEMPLATE_NAME=invoice_monthly_prompt

# ============================================================
# LLM (local Ollama)
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# ============================================================
# Email (Microsoft Graph API, client-credentials flow)
# ============================================================
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_MAIL_USER=                       # mailbox to send "from", e.g. yashdeep@aeologic.com
ATTACHMENT_SAVE_PATH=uploads/attachments
ACCOUNTS_EMAIL=                        # comma-separated if multiple
CC_EMAIL=

# ============================================================
# Invoice
# ============================================================
COMPANY_NAME=Aeologic Technologies Ltd.
INVOICE_AMOUNT_INR=
INVOICE_DAY_OF_MONTH=25
INVOICE_TIME_LOCAL=10:30               # 24h, local time
TIMEZONE=Asia/Kolkata

# ============================================================
# Webhook
# ============================================================
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_SHARED_SECRET=

# ============================================================
# Storage
# ============================================================
SQLITE_PATH=./data/invoice_agent.db
